# Backend production env — copy to .env.production (gitignored) and fill in.
# Apply once with:  ./scripts/set-env.sh
# Cloud Run KEEPS these across deploys, so you do NOT re-run on every build —
# only when you change a value.

# ── Required ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
SECRET_KEY=change-me-to-a-random-32+char-string
ADMIN_EMAIL=brunodossantos707@gmail.com
ADMIN_PASSWORD=your-strong-password
CRON_SECRET=another-random-string
GMAIL_APP_PASSWORD=your-gmail-app-password

# ── Optional (unlock more) ──────────────────────────────────
INSURANCE_GMAIL_APP_PASSWORD=
JOBS_API_KEY=
GCS_BUCKET=
SOCIAL_AUTO_PUBLISH=false
INSTAGRAM_AUTO_PUBLISH=false
# DATABASE_URL is already set on the service — do NOT put it here.
