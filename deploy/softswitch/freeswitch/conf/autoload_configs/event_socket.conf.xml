<configuration name="event_socket.conf" description="Socket Client">
  <settings>
    <param name="nat-map" value="false"/>
    <!-- Bind ESL. Keep this on a PRIVATE interface/network — the backend reaches
         it to originate calls. Do NOT port-forward 8021 to the public internet. -->
    <param name="listen-ip" value="0.0.0.0"/>
    <param name="listen-port" value="8021"/>
    <param name="password" value="$${ESL_PASSWORD}"/>
    <!-- Only loopback by default. To let the Bruno backend connect from another
         host on your private network, add its subnet to an ACL in acl.conf.xml
         and reference it here, e.g. apply-inbound-acl="lan". -->
    <param name="apply-inbound-acl" value="loopback.auto"/>
  </settings>
</configuration>
