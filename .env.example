# ── Core ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-long-random-string
# Fernet key used to encrypt stored third-party API keys at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-a-fernet-key

# ── Database ─────────────────────────────────────────────────────────
POSTGRES_USER=bruno
POSTGRES_PASSWORD=bruno
POSTGRES_DB=bruno_ai
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://bruno:bruno@db:5432/bruno_ai

# ── Redis (queues) ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ─────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Seed admin user created on first boot (see backend/seed.py)
ADMIN_EMAIL=brunodossantos707@gmail.com
ADMIN_PASSWORD=change-me

# ── OpenAI ───────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Scheduler ────────────────────────────────────────────────────────
# Set to true to run agents on their daily cron schedule.
ENABLE_SCHEDULER=true
TIMEZONE=America/New_York

# ── Email (daily CEO report) ─────────────────────────────────────────
# The report prefers Gmail (personal account below); SMTP is a fallback.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_FROM_EMAIL=
REPORT_TO_EMAIL=brunodossantos707@gmail.com

# ── Gmail (outbound + inbound), two accounts ─────────────────────────
# Mint a token per account: python -m app.scripts.gmail_auth client_secret.json
# Then paste the printed JSON (one line) into the *_TOKEN_JSON var.
# Outbound mode: send | send_on_approve | draft
GMAIL_OUTBOUND_MODE=send
GMAIL_DAILY_SEND_CAP=50

# Personal account — used by all agents EXCEPT insurance, and the CEO report.
GMAIL_ADDRESS=brunodossantos707@gmail.com
GOOGLE_TOKEN_JSON=
# (or) GOOGLE_OAUTH_CLIENT_ID / _SECRET / _REFRESH_TOKEN
GOOGLE_OAUTH_REFRESH_TOKEN=

# Insurance account — used by the Insurance agent's outreach.
INSURANCE_GMAIL_ADDRESS=bruno@thrustinsurance.com
INSURANCE_GOOGLE_TOKEN_JSON=
INSURANCE_GOOGLE_OAUTH_CLIENT_ID=
INSURANCE_GOOGLE_OAUTH_CLIENT_SECRET=
INSURANCE_GOOGLE_OAUTH_REFRESH_TOKEN=

# ── Integrations (Phase 2) ───────────────────────────────────────────
# HubSpot: qualified insurance leads (score >= 60) are auto-pushed as contacts.
HUBSPOT_API_KEY=
# Apollo.io: live commercial insurance + restaurant prospect sourcing (B2B).
APOLLO_API_KEY=
INSTANTLY_API_KEY=
# Jobs: live executive postings via JSearch/Indeed aggregator (RapidAPI).
JOBS_API_KEY=
JOBS_API_HOST=jsearch.p.rapidapi.com
# Personal Google OAuth client (used with GOOGLE_TOKEN_JSON above)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Frontend ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
