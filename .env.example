# ── Core ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-long-random-string
# Fernet key used to encrypt stored third-party API keys at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-a-fernet-key

# ── Database ─────────────────────────────────────────────────────────
POSTGRES_USER=bruno
POSTGRES_PASSWORD=bruno
POSTGRES_DB=bruno_ai
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://bruno:bruno@db:5432/bruno_ai

# ── Redis (queues) ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ─────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Seed admin user created on first boot (see backend/seed.py)
ADMIN_EMAIL=brunodossantos707@gmail.com
ADMIN_PASSWORD=change-me

# ── OpenAI ───────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Scheduler ────────────────────────────────────────────────────────
# Set to true to run agents on their daily cron schedule.
ENABLE_SCHEDULER=true
TIMEZONE=America/New_York

# ── Email (daily CEO report) ─────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_FROM_EMAIL=
REPORT_TO_EMAIL=brunodossantos707@gmail.com

# ── Integrations (Phase 2) ───────────────────────────────────────────
HUBSPOT_API_KEY=
APOLLO_API_KEY=
INSTANTLY_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Frontend ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
